{
  "name": "solanaapp-reactnative",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "db:start": "npx supabase start",
    "db:stop": "npx supabase stop",
    "db:reset": "npx supabase db reset",
    "db:migrate": "npx supabase migration up",
    "db:generate": "npx supabase gen types typescript --local > src/types/supabase.ts",
    "db:seed": "npx supabase seed run",
    "start:api": "node api-server.js",
    "start:dev": "concurrently \"npm run start:api\" \"npm run start\""
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@solana/web3.js": "^1.98.4",
    "@supabase/supabase-js": "^2.57.4",
    "expo": "~54.0.30",
    "expo-linear-gradient": "^13.0.2",
    "expo-secure-store": "^13.0.2",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "^2.20.0",
    "react-native-reanimated": "^3.15.0",
    "react-native-safe-area-context": "^4.12.0",
    "react-native-screens": "^4.2.0",
    "react-native-svg": "^15.8.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "concurrently": "^9.2.1",
    "supabase": "^2.54.11",
    "typescript": "~5.9.2"
  },
  "private": true
}